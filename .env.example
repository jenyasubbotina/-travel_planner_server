# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/travel_planner
DATABASE_USER=tp_user
DATABASE_PASSWORD=tp_pass

# JWT
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_ISSUER=travel-planner
JWT_AUDIENCE=travel-planner-client
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRY_DAYS=30

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=travel-planner
S3_REGION=us-east-1

# FCM (optional — set path to Firebase service account JSON)
FCM_SERVICE_ACCOUNT_PATH=

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
